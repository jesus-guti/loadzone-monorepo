# ── Database ──────────────────────────────────────────
DATABASE_URL="postgresql://user:pass@ep-example-123456.eu-central-1.aws.neon.tech/loadzone?sslmode=require"

# ── Auth (NextAuth) ───────────────────────────────────
AUTH_SECRET="generate with: openssl rand -base64 32"
AUTH_TRUST_HOST="true"

# ── AI (optional) ─────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ── Storage (Vercel Blob) ─────────────────────────────
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ── Public URLs ───────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://app.loadzone.app"
NEXT_PUBLIC_PLAYER_URL="https://player.loadzone.app"
