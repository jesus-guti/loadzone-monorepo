{
  "name": "player",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3003",
    "build": "next build",
    "start": "next start",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "test:e2e": "pnpm tsx e2e/helpers/seed-test-data.ts --output e2e/seed-context.json && cd e2e && npx playwright test",
    "test:e2e:seed": "pnpm tsx e2e/helpers/seed-test-data.ts --output e2e/seed-context.json",
    "test:e2e:run": "cd e2e && npx playwright test",
    "test:e2e:report": "npx playwright show-report e2e/playwright-report"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/client": "7.1.0",
    "@repo/database": "workspace:*",
    "@repo/design-system": "workspace:*",
    "@repo/next-config": "workspace:*",
    "@t3-oss/env-nextjs": "^0.13.8",
    "framer-motion": "^12.38.0",
    "next": "16.0.10",
    "next-themes": "^0.4.6",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3"
  }
}
